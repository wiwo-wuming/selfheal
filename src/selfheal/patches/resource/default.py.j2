{# Resource / FileNotFound / Database error fix – skip when resource is missing #}
{%- set line = error_line or 1 -%}
{%- set ctx_lines = 3 -%}
--- a/{{ target_file }}
+++ b/{{ target_file }}
@@ -{{ [line - ctx_lines, 1] | max }},{{ ctx_lines * 2 + 1 }} +{{ [line - ctx_lines, 1] | max }},{{ ctx_lines * 2 + 10 }} @@
 {{ ' ' }}{{ original_code or '# (original resource-dependent code)' }}
+# SelfHeal: skip test when external resource is unavailable
+import pytest
+from pathlib import Path
+
+
+@pytest.mark.skipif(
+    not Path("{{ target_file }}").exists(){% if missing_module %} or not Path("{{ missing_module }}").exists(){% endif %},
+    reason="Required resource not available – skipping {{ error_func or 'test' }}"
+)
+def {{ error_func or 'test_resource' }}():
+    {{ original_code.strip() if original_code else '# (original resource-dependent logic)' }}
