{# RuntimeError fix – wraps code with specific exception handling #}
{%- set line = error_line or 1 -%}
{%- set ctx_lines = 3 -%}
--- a/{{ target_file }}
+++ b/{{ target_file }}
@@ -{{ [line - ctx_lines, 1] | max }},{{ ctx_lines * 2 + 1 }} +{{ [line - ctx_lines, 1] | max }},{{ ctx_lines * 2 + 10 }} @@
 {{ ' ' }}{{ original_code or '# (original failing code)' }}
+# SelfHeal: guarded {{ error_type }} with explicit check / try-except
+import pytest
+
+try:
+    {{ original_code.strip() if original_code else '# (re-run the guarded logic)' }}
+except {{ error_type }} as _selfheal_err:
+{% if error_type in ('TypeError', 'ValueError', 'KeyError') %}
+    pytest.skip(f"Input data issue: {_selfheal_err}")
+{% elif error_type == 'AttributeError' %}
+    pytest.skip(f"Optional attribute missing: {_selfheal_err}")
+{% elif error_type == 'ZeroDivisionError' %}
+    pytest.xfail(reason=f"Division by zero is expected in edge cases: {_selfheal_err}")
+{% elif error_type == 'FileNotFoundError' %}
+    pytest.skip(f"Required file not found: {_selfheal_err}")
+{% else %}
+    pytest.xfail(reason=f"{{ error_type }} is expected in this context: {_selfheal_err}")
+{% endif %}
